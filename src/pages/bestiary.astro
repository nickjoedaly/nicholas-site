---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCards = await getCollection('bestiary');
const freeCards = allCards.filter(c => c.data.tier === 'free');
const premiumCards = allCards.filter(c => c.data.tier === 'premium');

// Suite colors for display
const suiteColors: Record<string, { color: string; bg: string }> = {
  Timbre: { color: '#6b4c8a', bg: '#f0eaf5' },
  Form: { color: '#2a7a5a', bg: '#e8f5ee' },
  Harmony: { color: '#b85c20', bg: '#faf0e6' },
  Melody: { color: '#3a6a9a', bg: '#e8f0f8' },
  Rhythm: { color: '#8a3a5a', bg: '#f8e8f0' },
  Development: { color: '#5a6a3a', bg: '#f0f4e8' },
  Instrumentation: { color: '#7a5a4a', bg: '#f4ece8' },
};

// Count cards per suite
const suiteCounts: Record<string, number> = {};
for (const card of allCards) {
  suiteCounts[card.data.suite] = (suiteCounts[card.data.suite] || 0) + 1;
}
---

<BaseLayout title="Compositional Bestiary — Nicholas Composer">
  <div class="hero">
    <div class="hero-inner container">
      <div>
        <div class="hero-sub mono">A compositional card game</div>
        <h1>The Compositional <em>Bestiary</em></h1>
        <p class="hero-desc">A deck of techniques, constraints, and provocations. Draw a card — it tells you what to write. Use it to generate new work, workshop existing pieces, or simply wonder at what's possible.</p>
        <div class="hero-actions">
          <a class="btn btn-gold" href="#purchase">Get the deck — $55</a>
          <a class="btn btn-outline" href="#draw">Try it now</a>
        </div>
      </div>
      <div class="card-fan" id="cardFan"></div>
    </div>
  </div>

  <div class="content">
    <!-- How it works -->
    <div class="section">
      <div class="section-head">
        <div class="section-title">Three ways to play</div>
        <div class="section-sub mono">Generate, workshop, or wonder</div>
      </div>
      <div class="how-grid">
        <div class="how-card">
          <div class="how-icon">G</div>
          <div class="how-title">Generate</div>
          <div class="how-desc">Draw cards to define the parameters of a new piece. Like a tarot spread for composition — each position governs a different musical dimension.</div>
        </div>
        <div class="how-card">
          <div class="how-icon">W</div>
          <div class="how-title">Workshop</div>
          <div class="how-desc">Apply cards to a work-in-progress. Stuck on a development section? Draw a card and let it suggest a way forward.</div>
        </div>
        <div class="how-card">
          <div class="how-icon">?</div>
          <div class="how-title">Wonder</div>
          <div class="how-desc">Browse the deck as a compendium of compositional possibility. Each card is a doorway into a technique you might not have considered.</div>
        </div>
      </div>
    </div>

    <!-- Card types -->
    <div class="section">
      <div class="section-head">
        <div class="section-title">Card types</div>
        <div class="section-sub mono">Every card serves a different role in the compositional process</div>
      </div>
      <div class="type-row">
        <div class="type-badge active"><div class="type-name">Generative</div><div class="type-desc">Seed a new idea</div></div>
        <div class="type-badge"><div class="type-name">Workshop</div><div class="type-desc">Refine existing work</div></div>
        <div class="type-badge"><div class="type-name">Wonder</div><div class="type-desc">Expand your thinking</div></div>
        <div class="type-badge"><div class="type-name">Constraint</div><div class="type-desc">Impose a limitation</div></div>
      </div>
    </div>

    <!-- Suites -->
    <div class="section">
      <div class="section-head">
        <div class="section-title">Suites</div>
        <div class="section-sub mono">Cards are organized by the musical dimension they address</div>
      </div>
      <div class="suite-grid">
        {Object.entries(suiteColors).map(([suite, colors]) => (
          <div class="suite-card" style={`background:${colors.bg};border-color:${colors.bg}`}>
            <div class="suite-name" style={`color:${colors.color}`}>{suite}</div>
            <div class="suite-count" style={`color:${colors.color}`}>{suiteCounts[suite] || 0} cards</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Interactive draw -->
    <div class="draw-section" id="draw">
      <div class="draw-inner">
        <div class="draw-title">Draw from the deck</div>
        <div class="draw-sub mono">Try the Bestiary right here. Choose a draw mode and see what the cards demand.</div>
        <div class="draw-controls">
          <button class="draw-btn active" data-count="1">Single card</button>
          <button class="draw-btn" data-count="3">Three-card spread</button>
          <button class="draw-btn" data-count="5">Full generative spread</button>
          <button class="draw-btn draw-go">Draw</button>
        </div>
        <div class="drawn-cards" id="drawnCards">
          <div class="draw-placeholder">Choose a mode and draw</div>
        </div>
        <button class="draw-reset" id="drawReset">Clear and draw again</button>
      </div>
    </div>

    <!-- Play modes -->
    <div class="section">
      <div class="section-head">
        <div class="section-title">Play modes</div>
        <div class="section-sub mono">Multiple rulesets for different creative needs</div>
      </div>
      <div class="mode-grid">
        <div class="mode-card">
          <div class="mode-label mono">Generative</div>
          <div class="mode-title">The Spread</div>
          <div class="mode-desc">Lay out cards in positions that govern melody, harmony, rhythm, form, and character.</div>
          <div class="mode-example">Position 1: Melody<br>Position 2: Harmony<br>Position 3: Rhythm<br>Position 4: Form<br>Position 5: Character / wild</div>
        </div>
        <div class="mode-card">
          <div class="mode-label mono">Workshop</div>
          <div class="mode-title">The Swap</div>
          <div class="mode-desc">Draw cards to challenge specific aspects of an existing piece. Swap, replace, or layer constraints.</div>
          <div class="mode-example">Draw 3 cards. Choose one to apply.<br>Discard one element of your piece.<br>Replace it with the card's technique.</div>
        </div>
        <div class="mode-card">
          <div class="mode-label mono">Collaborative</div>
          <div class="mode-title">The Round</div>
          <div class="mode-desc">Multiple composers draw from the same deck, building a collective set of constraints together.</div>
          <div class="mode-example">Each player draws 2 cards.<br>Take turns adding to the spread.<br>Discuss, negotiate, compose.</div>
        </div>
        <div class="mode-card">
          <div class="mode-label mono">Reflective</div>
          <div class="mode-title">The Browse</div>
          <div class="mode-desc">No game mechanics — simply read through the deck as a compendium of techniques and possibilities.</div>
          <div class="mode-example">Read one card per day.<br>Consider how it applies to your<br>current work or thinking.</div>
        </div>
      </div>
    </div>

    <!-- Purchase -->
    <div class="section" id="purchase">
      <div class="section-head">
        <div class="section-title">Get the Bestiary</div>
        <div class="section-sub mono">Available as a physical deck or digital download</div>
      </div>
      <div class="purchase-section">
        <div class="purchase-grid">
          <div class="purchase-option">
            <div class="po-label mono">Physical edition</div>
            <div class="po-title">Printed deck</div>
            <div class="po-price">$55</div>
            <div class="po-ship mono">Free shipping within the US</div>
            <div class="po-desc">Professionally printed cards on heavyweight stock with a custom tuck box. Designed to live on your music stand, piano, or desk.</div>
            <ul class="po-includes">
              <li>85 cards on 350gsm cardstock, full color</li>
              <li>Instruction booklet with all play modes</li>
              <li>Custom magnetic-close tuck box</li>
              <li>Digital version included free</li>
            </ul>
            <button class="po-btn primary">Order physical deck — $55</button>
          </div>
          <div class="purchase-option">
            <div class="po-label mono">Digital edition</div>
            <div class="po-title">PDF + web app</div>
            <div class="po-price">$20</div>
            <div class="po-ship mono">Instant download</div>
            <div class="po-desc">Print-at-home PDF with full card designs, plus lifetime access to the web-based draw tool with all play modes built in.</div>
            <ul class="po-includes">
              <li>Print-ready PDF (all 85 cards)</li>
              <li>Web app with interactive draw</li>
              <li>Instruction PDF with all play modes</li>
              <li>All future card additions included</li>
            </ul>
            <button class="po-btn">Download digital — $20</button>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="section">
      <div class="section-head">
        <div class="section-title">Questions & background</div>
      </div>
      <div class="faq-list">
        <div class="faq-item open">
          <div class="faq-q">
            <span class="faq-q-text">How did the Bestiary come to exist?</span>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-a">
            <p>It started as a private notebook — index cards kept during my PhD, each one a compositional technique encountered in the repertoire, lessons, or experiments. That stack grew into something more structured, categorized by musical dimension, and the idea of a game emerged naturally.</p>
          </div>
        </div>
        <div class="faq-item">
          <div class="faq-q">
            <span class="faq-q-text">I'm a professional composer. What's in this for me?</span>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-a">
            <p>The value for experienced composers isn't the techniques themselves — it's the combinatorics and the disruption of habit. The Bestiary forces juxtapositions you'd never choose voluntarily. The most productive moments come from cards you initially want to reject.</p>
          </div>
        </div>
        <div class="faq-item">
          <div class="faq-q">
            <span class="faq-q-text">How is this different from Brian Eno's Oblique Strategies?</span>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-a">
            <p>Oblique Strategies are deliberately abstract and medium-agnostic. The Bestiary is music-specific and technique-concrete: every card names a real compositional procedure. It also has structured play modes that give the cards a game dimension. If Oblique Strategies is a Zen koan, the Bestiary is a field guide.</p>
          </div>
        </div>
        <div class="faq-item">
          <div class="faq-q">
            <span class="faq-q-text">Will new cards be added over time?</span>
            <span class="faq-toggle">+</span>
          </div>
          <div class="faq-a">
            <p>Yes. The digital edition includes all future card additions at no extra cost. Physical deck owners receive print-at-home PDFs of expansion cards.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ cards: freeCards.map(c => ({ id: c.id, ...c.data })) }}>
// Suite color mapping
var suiteStyles = {
  Timbre: { color: '#6b4c8a', bg: '#f0eaf5' },
  Form: { color: '#2a7a5a', bg: '#e8f5ee' },
  Harmony: { color: '#b85c20', bg: '#faf0e6' },
  Melody: { color: '#3a6a9a', bg: '#e8f0f8' },
  Rhythm: { color: '#8a3a5a', bg: '#f8e8f0' },
  Development: { color: '#5a6a3a', bg: '#f0f4e8' },
  Instrumentation: { color: '#7a5a4a', bg: '#f4ece8' },
};

var drawCount = 1;
var spreadLabels = {
  1: [''],
  3: ['Seed', 'Development', 'Resolution'],
  5: ['Melody', 'Harmony', 'Rhythm', 'Form', 'Character'],
};

// Draw mode buttons
document.querySelectorAll('.draw-btn[data-count]').forEach(function(btn) {
  btn.addEventListener('click', function() {
    drawCount = parseInt(btn.dataset.count);
    document.querySelectorAll('.draw-btn[data-count]').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
  });
});

// Draw button
document.querySelector('.draw-go').addEventListener('click', function() {
  var container = document.getElementById('drawnCards');
  container.innerHTML = '';
  var shuffled = cards.slice().sort(function() { return Math.random() - 0.5; });
  var labels = spreadLabels[drawCount] || [''];

  for (var i = 0; i < Math.min(drawCount, shuffled.length); i++) {
    var c = shuffled[i];
    var s = suiteStyles[c.suite] || { color: '#666', bg: '#eee' };
    var label = labels[i] || '';
    var card = document.createElement('div');
    card.className = 'drawn-card';
    card.style.animationDelay = (i * 0.12) + 's';
    card.innerHTML =
      (label ? '<div class="dc-position">Position: ' + label + '</div>' : '') +
      '<div class="dc-suite" style="background:' + s.bg + ';color:' + s.color + '">' + c.suite + '</div>' +
      '<div class="dc-name">' + c.name + '</div>' +
      '<div class="dc-type">' + c.type + '</div>' +
      '<div class="dc-desc">' + c.desc + '</div>' +
      '<div class="dc-prompt">"' + c.prompt + '"</div>';
    container.appendChild(card);
  }
});

// Reset
document.getElementById('drawReset').addEventListener('click', function() {
  document.getElementById('drawnCards').innerHTML = '<div class="draw-placeholder">Choose a mode and draw</div>';
});

// Hero card fan — show first 5 cards fanned
var fanCards = cards.slice(0, 5);
var fan = document.getElementById('cardFan');
fanCards.forEach(function(c, i) {
  var s = suiteStyles[c.suite] || { color: '#666', bg: '#eee' };
  var el = document.createElement('div');
  el.className = 'fan-card';
  var angle = (i - 2) * 9;
  var xOff = 40 + i * 52;
  var yOff = Math.abs(i - 2) * 14;
  el.style.left = xOff + 'px';
  el.style.top = yOff + 'px';
  el.style.transform = 'rotate(' + angle + 'deg)';
  el.style.zIndex = String(i);
  el.innerHTML =
    '<div class="fc-color-bar" style="background:' + s.color + '"></div>' +
    '<div class="fc-top"><div class="fc-suite-pill" style="background:' + s.bg + ';color:' + s.color + '">' + c.suite + '</div><div class="fc-type-pill">' + c.type + '</div></div>' +
    '<div class="fc-body"><div class="fc-name">' + c.name + '</div><div class="fc-desc">' + c.desc + '</div></div>' +
    '<div class="fc-prompt">"' + c.prompt + '"</div>' +
    '<div class="fc-card-num">' + c.cardNumber + '</div>';
  el.addEventListener('mouseenter', function() { this.style.transform = 'rotate(' + angle + 'deg) translateY(-14px)'; });
  el.addEventListener('mouseleave', function() { this.style.transform = 'rotate(' + angle + 'deg)'; });
  fan.appendChild(el);
});

// FAQ toggle
document.querySelectorAll('.faq-item').forEach(function(item) {
  item.querySelector('.faq-q').addEventListener('click', function() {
    var wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(function(el) { el.classList.remove('open'); });
    if (!wasOpen) item.classList.add('open');
  });
});
</script>

<style is:global>
  /* Suite color vars */
  :root {
    --suite-timbre: #6b4c8a; --suite-timbre-bg: #f0eaf5;
    --suite-form: #2a7a5a; --suite-form-bg: #e8f5ee;
    --suite-harmony: #b85c20; --suite-harmony-bg: #faf0e6;
    --suite-melody: #3a6a9a; --suite-melody-bg: #e8f0f8;
    --suite-rhythm: #8a3a5a; --suite-rhythm-bg: #f8e8f0;
    --suite-dev: #5a6a3a; --suite-dev-bg: #f0f4e8;
    --suite-instr: #7a5a4a; --suite-instr-bg: #f4ece8;
  }

  /* Hero */
  .hero { background: var(--navy); padding: 3rem 0 3.5rem; border-bottom: 2px solid var(--gold); position: relative; overflow: hidden; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .hero h1 { font-size: 42px; font-weight: 300; color: var(--cream); letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 8px; }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-sub { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold); opacity: 0.7; margin-bottom: 16px; }
  .hero-desc { font-family: 'Source Serif 4', serif; font-size: 16px; color: var(--cream-dark); opacity: 0.6; line-height: 1.65; max-width: 420px; margin-bottom: 20px; }
  .hero-actions { display: flex; gap: 10px; }
  .btn { padding: 10px 22px; border-radius: 6px; font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.03em; cursor: pointer; transition: all 0.2s; border: 1px solid transparent; display: inline-block; }
  .btn-gold { background: var(--gold); color: var(--navy); font-weight: 500; border-color: var(--gold); }
  .btn-gold:hover { background: var(--gold-light); }
  .btn-outline { background: transparent; color: var(--cream); border-color: rgba(245,240,232,0.3); }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  /* Card fan */
  .card-fan { position: relative; width: 100%; height: 340px; }
  .fan-card { position: absolute; width: 190px; height: 270px; border-radius: 10px; border: 1px solid rgba(245,240,232,0.2); background: #f5f0e8; display: flex; flex-direction: column; transition: transform 0.4s, box-shadow 0.3s; cursor: pointer; overflow: hidden; }
  .fan-card:hover { z-index: 10 !important; box-shadow: 0 8px 30px rgba(0,0,0,0.3); }
  .fc-color-bar { height: 4px; width: 100%; flex-shrink: 0; }
  .fc-top { padding: 10px 14px 0; display: flex; justify-content: space-between; align-items: flex-start; }
  .fc-suite-pill { font-family: 'DM Mono', monospace; font-size: 7px; text-transform: uppercase; letter-spacing: 0.08em; padding: 2px 7px; border-radius: 2px; }
  .fc-type-pill { font-family: 'DM Mono', monospace; font-size: 7px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-light); }
  .fc-body { padding: 8px 14px; flex: 1; }
  .fc-name { font-family: 'Source Serif 4', serif; font-size: 14px; font-weight: 600; color: var(--text-dark); line-height: 1.2; margin-bottom: 4px; }
  .fc-desc { font-family: 'Source Serif 4', serif; font-size: 9px; color: var(--text-mid); line-height: 1.45; }
  .fc-prompt { font-family: 'Source Serif 4', serif; font-size: 8px; color: var(--gold-muted); font-style: italic; padding: 8px 14px; border-top: 1px solid var(--cream-dark); margin-top: auto; line-height: 1.4; }
  .fc-card-num { font-family: 'DM Mono', monospace; font-size: 7px; color: var(--text-light); padding: 0 14px 8px; text-align: right; }

  .content { max-width: 1280px; margin: 0 auto; padding: 2.5rem 2rem; }
  .section { margin-bottom: 3rem; }
  .section-head { margin-bottom: 1.25rem; }
  .section-title { font-family: 'Source Serif 4', serif; font-size: 22px; font-weight: 600; margin-bottom: 4px; }
  .section-sub { font-size: 11px; color: var(--text-light); }

  /* How it works */
  .how-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  .how-card { background: white; border: 1px solid var(--cream-dark); border-radius: 8px; padding: 20px; transition: border-color 0.2s; }
  .how-card:hover { border-color: var(--gold); }
  .how-icon { width: 40px; height: 40px; border-radius: 8px; background: var(--gold-pale); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; font-family: 'Source Serif 4', serif; font-size: 18px; font-weight: 600; color: var(--gold-muted); }
  .how-title { font-family: 'Source Serif 4', serif; font-size: 16px; font-weight: 600; margin-bottom: 6px; }
  .how-desc { font-family: 'Source Serif 4', serif; font-size: 13px; color: var(--text-mid); line-height: 1.6; }

  /* Card types */
  .type-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .type-badge { padding: 10px 20px; border: 1px solid var(--cream-dark); border-radius: 8px; background: white; cursor: pointer; transition: all 0.2s; text-align: center; flex: 1; min-width: 140px; }
  .type-badge:hover { border-color: var(--gold); }
  .type-badge.active { border-color: var(--gold); background: var(--gold-pale); }
  .type-name { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 500; color: var(--text-dark); margin-bottom: 2px; }
  .type-desc { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--text-light); }

  /* Suites */
  .suite-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
  .suite-card { padding: 14px; border-radius: 8px; border: 1px solid; transition: transform 0.2s; cursor: pointer; }
  .suite-card:hover { transform: translateY(-2px); }
  .suite-name { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 500; margin-bottom: 2px; }
  .suite-count { font-family: 'DM Mono', monospace; font-size: 9px; opacity: 0.6; }

  /* Draw section */
  .draw-section { background: var(--navy); border-radius: 10px; padding: 2.5rem; margin-bottom: 3rem; }
  .draw-inner { position: relative; z-index: 1; }
  .draw-title { font-family: 'Source Serif 4', serif; font-size: 22px; font-weight: 400; color: var(--cream); margin-bottom: 4px; }
  .draw-sub { font-size: 11px; color: var(--cream-dark); opacity: 0.5; margin-bottom: 24px; }
  .draw-controls { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
  .draw-btn { padding: 8px 18px; border-radius: 6px; font-family: 'DM Mono', monospace; font-size: 11px; cursor: pointer; transition: all 0.2s; border: 1px solid rgba(245,240,232,0.2); background: transparent; color: var(--cream-dark); }
  .draw-btn:hover { border-color: var(--gold); color: var(--gold); }
  .draw-btn.active { background: var(--gold); color: var(--navy); border-color: var(--gold); font-weight: 500; }
  .draw-go { background: var(--gold) !important; color: var(--navy) !important; border-color: var(--gold) !important; font-weight: 500; }
  .drawn-cards { display: flex; gap: 14px; flex-wrap: wrap; min-height: 200px; align-items: flex-start; }
  @keyframes dealIn { from { opacity: 0; transform: translateY(20px) rotate(-3deg); } to { opacity: 1; transform: translateY(0) rotate(0); } }
  .drawn-card { width: 180px; border-radius: 8px; border: 1px solid rgba(245,240,232,0.15); background: rgba(245,240,232,0.06); padding: 16px; animation: dealIn 0.4s ease-out; display: flex; flex-direction: column; gap: 8px; }
  .dc-position { font-family: 'DM Mono', monospace; font-size: 8px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); opacity: 0.6; }
  .dc-suite { font-family: 'DM Mono', monospace; font-size: 8px; text-transform: uppercase; letter-spacing: 0.08em; padding: 2px 8px; border-radius: 2px; display: inline-block; align-self: flex-start; }
  .dc-name { font-family: 'Source Serif 4', serif; font-size: 16px; font-weight: 600; color: var(--cream); line-height: 1.2; }
  .dc-type { font-family: 'DM Mono', monospace; font-size: 8px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--cream-dark); opacity: 0.5; }
  .dc-desc { font-family: 'Source Serif 4', serif; font-size: 11px; color: var(--cream-dark); opacity: 0.5; line-height: 1.5; }
